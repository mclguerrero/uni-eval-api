generator client {
  provider = "prisma-client-js"
  output   = "../../src/prisma/auth"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL_AUTH")
}

// Base remota de autenticación (solo lectura)
// Tabla: datalogin
model datalogin {
  user_id       Int    @id @db.Int
  user_name     String @db.VarChar(64)
  user_username String @db.VarChar(255)
  user_password String @db.VarChar(400)
  user_email    String @db.VarChar(255)
  user_idrole   Int    @db.Int
  user_statusid String @db.VarChar(1)
  role_name     String @db.VarChar(255)
}

// IMPORTANTE: No crear migraciones para esta base. Solo lectura.
